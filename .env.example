# Copy to `.env.local` when you add backend or analytics (never commit `.env.local`).
# CaseloadFlow MVP uses browser localStorage only. This file is for future Supabase/Vercel keys.

# Optional: PostHog (product analytics). If NEXT_PUBLIC_POSTHOG_KEY is unset, tracking no-ops.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: external feedback form URL. If unset, "Give feedback" opens an in-app modal with a mailto fallback.
# NEXT_PUBLIC_FEEDBACK_FORM_URL=

# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Vercel / monitoring (only if you add them)
# NEXT_PUBLIC_* variables are exposed to the browser; never put secrets there.
