# Copy to `.env.local` when you add backend or analytics (never commit `.env.local`).
# CaseloadFlow MVP uses browser localStorage only — this file is for future Supabase/Vercel keys.

# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Vercel / monitoring (only if you add them)
# NEXT_PUBLIC_* variables are exposed to the browser — never put secrets there.
