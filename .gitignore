# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Secrets & local config (never commit real values) ---
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.crt
credentials.json
*-credentials.json
service-account*.json
.secrets/
secrets/

# Cursor / IDE — ignore files that often hold API keys (keep .cursor/rules if you use them)
.cursor/mcp.json
.cursor/mcp.*.json
.idea/
*.swp
*.swo

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
dist/

# misc
.DS_Store
Thumbs.db

# debug & logs (can include paths or tokens in stack traces)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# vercel
.vercel

# typescript
*.tsbuildinfo

# caches
.turbo
.cache

# local databases / exports (if you add them later)
*.sqlite
*.sqlite3
*.db
